{
  "name": "git-vm-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply git_vm_oracle --local",
    "db:migrate:remote": "wrangler d1 migrations apply git_vm_oracle --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.ts\" \"web/src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8",
    "wrangler": "^4.101.0"
  }
}
